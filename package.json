{
  "name": "iotdb-real-time",
  "version": "0.0.1",
  "private": true,
  "lint-staged": {
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "node_modules/.bin/eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "node_modules/.bin/stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest --environment jsdom --root src/",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint-css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.4.0",
    "@codemirror/commands": "^6.1.3",
    "@codemirror/lang-sql": "^6.3.3",
    "@codemirror/language": "^6.3.2",
    "@codemirror/state": "^6.2.0",
    "@codemirror/view": "^6.7.2",
    "@intlify/unplugin-vue-i18n": "^0.8.1",
    "@vueuse/components": "^9.12.0",
    "@vueuse/core": "^9.10.0",
    "axios": "^1.2.2",
    "codemirror": "^6.0.1",
    "crypto-js": "^4.1.1",
    "dayjs": "^1.11.7",
    "echarts": "^5.4.1",
    "element-plus": "^2.2.28",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.0.28",
    "pinia-plugin-persistedstate": "^3.0.1",
    "vue": "^3.2.45",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@iconify-json/ep": "^1.1.8",
    "@rushstack/eslint-patch": "^1.2.0",
    "@types/crypto-js": "^4.1.1",
    "@types/jsdom": "^20.0.1",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.11.18",
    "@types/nprogress": "^0.2.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-airbnb-with-typescript": "^7.0.0",
    "@vue/test-utils": "^2.2.7",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^8.31.0",
    "eslint-plugin-vue": "^9.8.0",
    "husky": "^8.0.3",
    "jsdom": "^20.0.3",
    "lint-staged": "^13.1.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.57.1",
    "stylelint": "^14.16.1",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard-scss": "^6.1.0",
    "typescript": "~4.9.4",
    "unplugin-auto-import": "^0.12.1",
    "unplugin-icons": "^0.15.0",
    "unplugin-vue-components": "^0.22.12",
    "vite": "^4.0.4",
    "vite-plugin-inspect": "^0.7.12",
    "vitest": "^0.26.3",
    "vue-tsc": "^1.0.22"
  }
}