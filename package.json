{
  "name": "iotdb-workbench",
  "version": "2.2.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "lint-staged": {
    "*": [
      "node_modules/.bin/prettier --write"
    ],
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "node_modules/.bin/eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "node_modules/.bin/stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:historian": "vite --mode historian",
    "dev:workbench": "vite --mode workbench",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:historian": "run-p type-check \"build-only:historian {@}\" --",
    "build:workbench": "run-p type-check \"build-only:workbench {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-only:historian": "vite build --mode historian",
    "build-only:workbench": "vite build --mode workbench",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .prettierignore",
    "lint:eslint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@alova/adapter-axios": "^2.0.17",
    "@antv/x6": "^3.1.3",
    "@antv/x6-vue-shape": "^3.0.2",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.39.4",
    "@intlify/unplugin-vue-i18n": "^11.0.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@monaco-editor/loader": "^1.7.0",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^14.1.0",
    "alova": "^3.4.1",
    "axios": "^1.13.2",
    "codemirror": "^6.0.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "element-plus": "2.13.0",
    "jiti": "^2.6.1",
    "lodash-es": "^4.17.22",
    "lodash-unified": "^1.0.3",
    "monaco-editor": "^0.55.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "3.5.26",
    "vue-i18n": "11.2.7",
    "vue-router": "4.6.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@iconify-json/ep": "^1.2.3",
    "@prettier/plugin-oxc": "^0.1.3",
    "@rushstack/eslint-patch": "^1.15.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^27.0.0",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3",
    "@types/nprogress": "^0.2.3",
    "@unocss/preset-wind3": "^66.5.10",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-standard-with-typescript": "^9.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.34.0",
    "eslint-plugin-vue": "~10.6.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.34.0",
    "prettier": "3.7.4",
    "sass": "^1.97.1",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3",
    "unocss": "^66.5.10",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-icons": "^22.5.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1"
  }
}
