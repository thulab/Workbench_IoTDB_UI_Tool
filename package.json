{
  "name": "iotdb-workbench",
  "version": "2.3.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "lint-staged": {
    "*": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:historian": "vite --mode historian",
    "dev:workbench": "vite --mode workbench",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:historian": "run-p type-check \"build-only:historian {@}\" --",
    "build:workbench": "run-p type-check \"build-only:workbench {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-only:historian": "vite build --mode historian",
    "build-only:workbench": "vite build --mode workbench",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .prettierignore",
    "lint:eslint": "eslint . --fix",
    "format": "prettier --write src/",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:typecheck": "tsc -p tsconfig.e2e.json --noEmit",
    "test:e2e:real": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test",
    "test:e2e:real:headed": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test --headed",
    "test:e2e:login:real": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --project=chromium --workers=1",
    "test:e2e:login:real:headed": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --project=chromium --headed --workers=1",
    "test:e2e:login:real:report": "node tests/e2e/scripts/run-playwright-report.mjs --report-key login-real-report --spec tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --project chromium --workers 1",
    "test:e2e:login:real:headed:report": "node tests/e2e/scripts/run-playwright-report.mjs --report-key login-real-headed-report --spec tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --project chromium --workers 1 --headed",
    "test:e2e:instance:real": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test tests/e2e/Test_Cases/Tree_Model/Instance_Management/instance-management.spec.ts --project=chromium --workers=1",
