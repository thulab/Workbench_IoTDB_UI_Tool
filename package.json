{
  "name": "iotdb-workbench",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "lint-staged": {
    "*": [
      "node_modules/.bin/prettier --write"
    ],
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "node_modules/.bin/eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "node_modules/.bin/stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:historian": "vite --mode historian",
    "dev:workbench": "vite --mode workbench",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:historian": "run-p type-check \"build-only:historian {@}\" --",
    "build:workbench": "run-p type-check \"build-only:workbench {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-only:historian": "vite build --mode historian",
    "build-only:workbench": "vite build --mode workbench",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "run-s lint:*",
    "lint:css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .prettierignore",
    "lint:eslint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@alova/adapter-axios": "^2.0.16",
    "@antv/x6": "^2.18.1",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-scroller": "^2.0.10",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-plugin-stencil": "^2.1.5",
    "@antv/x6-plugin-transform": "^2.1.8",
    "@antv/x6-vue-shape": "^2.1.2",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-sql": "^6.9.1",
    "@codemirror/language": "^6.11.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@monaco-editor/loader": "^1.5.0",
    "@vueuse/components": "^13.6.0",
    "@vueuse/core": "^13.6.0",
    "alova": "^3.3.4",
    "axios": "^1.11.0",
    "codemirror": "^6.0.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "echarts": "^5.6.0",
    "element-plus": "2.10.4",
    "jiti": "^2.5.1",
    "lodash-es": "^4.17.21",
    "lodash-unified": "^1.0.3",
    "monaco-editor": "^0.52.2",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.4.1",
    "vue": "3.5.18",
    "vue-i18n": "11.1.11",
    "vue-router": "4.5.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@iconify-json/ep": "^1.2.2",
    "@prettier/plugin-oxc": "^0.0.4",
    "@rushstack/eslint-patch": "^1.12.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.1.0",
    "@types/nprogress": "^0.2.3",
    "@unocss/preset-wind3": "^66.3.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-standard-with-typescript": "^9.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-oxlint": "~1.8.0",
    "eslint-plugin-vue": "~10.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.8.0",
    "prettier": "3.6.2",
    "sass": "^1.89.2",
    "stylelint": "^16.23.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.8.3",
    "unocss": "^66.3.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-element-plus": "^0.10.0",
    "unplugin-icons": "^22.2.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.4"
  }
}
