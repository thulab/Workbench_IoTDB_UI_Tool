    "test:e2e:dashboard:real": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test tests/e2e/Test_Cases/Tree_Model/Instance_Dashboard/dashboard.spec.ts --project=chromium --workers=1",
    "test:e2e:dashboard:real:headed": "set PLAYWRIGHT_REAL_BACKEND=true&& playwright test tests/e2e/Test_Cases/Tree_Model/Instance_Dashboard/dashboard.spec.ts --project=chromium --headed --workers=1",
