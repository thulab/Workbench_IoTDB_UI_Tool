{
  "name": "iotdb-workbench",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "lint-staged": {
    "*": [
      "node_modules/.bin/prettier --write"
    ],
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "node_modules/.bin/eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "node_modules/.bin/stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:historian": "vite --mode historian",
    "dev:workbench": "vite --mode workbench",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:historian": "run-p type-check \"build-only:historian {@}\" --",
    "build:workbench": "run-p type-check \"build-only:workbench {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-only:historian": "vite build --mode historian",
    "build-only:workbench": "vite build --mode workbench",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint-css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@antv/x6": "^2.18.1",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-scroller": "^2.0.10",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-plugin-stencil": "^2.1.5",
    "@antv/x6-plugin-transform": "^2.1.8",
    "@antv/x6-vue-shape": "^2.1.2",
    "@codemirror/autocomplete": "^6.18.1",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.10.3",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@intlify/unplugin-vue-i18n": "^5.2.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@monaco-editor/loader": "^1.4.0",
    "@vueuse/components": "^11.1.0",
    "@vueuse/core": "^11.1.0",
    "axios": "^1.7.7",
    "codemirror": "^6.0.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "element-plus": "2.8.5",
    "lodash-es": "^4.17.21",
    "lodash-unified": "^1.0.3",
    "monaco-editor": "^0.52.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.4",
    "pinia-plugin-persistedstate": "^4.1.1",
    "vue": "3.5.12",
    "vue-i18n": "10.0.4",
    "vue-router": "4.4.5",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@iconify-json/ep": "^1.2.1",
    "@rushstack/eslint-patch": "^1.10.4",
    "@tsconfig/node18": "^18.2.4",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.10",
    "@types/node": "^20.12.7",
    "@types/nprogress": "^0.2.3",
    "@unocss/preset-uno": "^0.63.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-airbnb-with-typescript": "^8.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.25.0",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "npm-run-all2": "^6.2.3",
    "prettier": "^3.3.3",
    "sass": "^1.79.5",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-prettier": "^5.0.2",
    "typescript": "~5.6.3",
    "unocss": "^0.63.4",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-element-plus": "^0.8.0",
    "unplugin-icons": "^0.19.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.9",
    "vite-plugin-vue-devtools": "^7.4.6",
    "vitest": "^2.1.3",
    "vue-tsc": "^2.1.6"
  }
}
