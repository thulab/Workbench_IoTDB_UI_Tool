    "test:e2e:full-dev": "node tests/e2e/scripts/run-e2e-entry.mjs full-dev",
    "test:e2e:full-dev:headed": "node tests/e2e/scripts/run-e2e-entry.mjs full-dev headed",
    "test:e2e:real:report": "node tests/e2e/scripts/run-playwright-report.mjs --report-key real-full-report --spec tests/e2e/Test_Cases/Tree_Model/Instance_Management/instance-management.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Instance_Dashboard/dashboard.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Measurement_Management/measurement-management.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Search/data-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Search/statistic-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/SQL_Search/sql-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Calculate_Detail/calculate.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Auth/User/user.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Auth/Role/role.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Audit/audit.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Config/config.spec.ts --project chromium --workers 1",
    "test:e2e:real:headed:report": "node tests/e2e/scripts/run-playwright-report.mjs --report-key real-full-report --spec tests/e2e/Test_Cases/Tree_Model/Instance_Management/instance-management.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Instance_Login/login.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Instance_Dashboard/dashboard.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Measurement_Management/measurement-management.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Search/data-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Search/statistic-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/SQL_Search/sql-search.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/Calculate_Detail/calculate.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Auth/User/user.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Auth/Role/role.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Audit/audit.spec.ts --spec tests/e2e/Test_Cases/Tree_Model/System/Config/config.spec.ts --project chromium --workers 1 --headed",
