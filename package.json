{
  "name": "iotdb-real-time",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,vue,ts,tsx}": [
      "node_modules/.bin/eslint --fix"
    ],
    "src/**/*.{css,scss,less,vue,html}": [
      "node_modules/.bin/stylelint --fix"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:workbench": "vite --mode workbench",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:workbench": "run-p type-check \"build-only:workbench {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-only:workbench": "vite build --mode workbench",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint-css": "stylelint src/**/*.{css,less,scss,vue} --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@antv/x6": "^2.16.1",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.1",
    "@antv/x6-plugin-scroller": "^2.0.10",
    "@antv/x6-plugin-selection": "^2.2.1",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-plugin-stencil": "^2.1.4",
    "@antv/x6-plugin-transform": "^2.1.8",
    "@antv/x6-vue-shape": "^2.1.1",
    "@codemirror/autocomplete": "^6.11.1",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-sql": "^6.5.5",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "@intlify/unplugin-vue-i18n": "^2.0.0",
    "@unocss/preset-uno": "^0.58.3",
    "@vueuse/components": "^10.7.1",
    "@vueuse/core": "^10.7.1",
    "axios": "^1.6.3",
    "codemirror": "^6.0.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "lodash-es": "^4.17.21",
    "lodash-unified": "^1.0.3",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "prettier": "^3.2.5",
    "unocss": "^0.58.3",
    "vue": "^3.4.3",
    "vue-i18n": "^9.8.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@iconify-json/ep": "^1.1.14",
    "@rushstack/eslint-patch": "^1.6.1",
    "@tsconfig/node18": "^18.2.2",
    "@types/crypto-js": "^4.2.1",
    "@types/jsdom": "^21.1.6",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.0.2",
    "@vue/eslint-config-airbnb-with-typescript": "^8.0.0",
    "@vue/test-utils": "^2.4.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^8.0.3",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.0",
    "npm-run-all2": "^6.1.1",
    "sass": "^1.69.7",
    "stylelint": "^16.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard-scss": "^12.0.0",
    "typescript": "~5.3.3",
    "unplugin-auto-import": "^0.17.3",
    "unplugin-element-plus": "^0.8.0",
    "unplugin-icons": "^0.18.1",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.10",
    "vite-plugin-vue-devtools": "^7.0.3",
    "vitest": "^1.1.1",
    "vue-tsc": "^1.8.27"
  }
}